@* KakeiboSetupBanner.razor — Modal prompting existing users to complete Kakeibo category setup *@
@using BudgetExperiment.Client.Components.Common
@using BudgetExperiment.Client.Services
@inject IBudgetApiService ApiService
@inject NavigationManager NavigationManager

<Modal IsVisible="@_showBanner"
       Title="Set Up Kakeibo"
       Size="ModalSize.Small"
       CloseOnOverlayClick="true"
       ShowCloseButton="true"
       OnClose="DismissAsync">
    <ChildContent>
        <p>✨ <strong>New:</strong> Kakeibo category setup available. Take 2 minutes to categorise your spending by intent.</p>
    </ChildContent>
    <FooterContent>
        <button class="btn btn-primary" @onclick="SetUpNow" type="button">Set up now</button>
        <button class="btn btn-ghost" @onclick="DismissAsync" type="button">Dismiss</button>
    </FooterContent>
</Modal>

@code {
    private bool _showBanner;

    /// <summary>
    /// Gets or sets a value indicating whether the user has completed the Kakeibo setup.
    /// When false, the banner is displayed.
    /// </summary>
    [Parameter]
    public bool HasCompletedKakeiboSetup { get; set; }

    /// <inheritdoc />
    protected override void OnParametersSet()
    {
        _showBanner = !HasCompletedKakeiboSetup;
    }

    private void SetUpNow()
    {
        NavigationManager.NavigateTo("/onboarding?step=kakeibo");
    }

    private async Task DismissAsync()
    {
        _showBanner = false;

        try
        {
            await ApiService.MarkKakeiboSetupCompleteAsync();
        }
        catch
        {
            // Best-effort dismiss; silently ignore if the request fails
        }
    }
}
