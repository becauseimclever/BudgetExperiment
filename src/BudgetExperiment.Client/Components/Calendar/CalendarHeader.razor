@using Microsoft.FluentUI.AspNetCore.Components

<FluentStack Orientation="Orientation.Horizontal" 
             HorizontalAlignment="HorizontalAlignment.Center" 
             VerticalAlignment="VerticalAlignment.Center" 
             Style="padding: 16px; border-bottom: 1px solid var(--neutral-stroke-divider);">
    <FluentButton Appearance="Appearance.Outline" 
                  OnClick="() => OnNavigateMonth.InvokeAsync(-1)"
                  Style="margin-right: 24px;">
        Previous
    </FluentButton>
    
    <FluentLabel Typo="Typography.PageTitle" 
                 Style="min-width: 200px; text-align: center;">
        @MonthName @Year
    </FluentLabel>
    
    <FluentButton Appearance="Appearance.Outline" 
                  OnClick="() => OnNavigateMonth.InvokeAsync(1)"
                  Style="margin-left: 24px;">
        Next
    </FluentButton>

    <FluentButton Appearance="Appearance.Accent"
                  OnClick="() => OnImportClick.InvokeAsync()"
                  Style="margin-left: 48px;">
        Import Transactions
    </FluentButton>

    @if (ShowQuickEntry)
    {
        <FluentButton Appearance="Appearance.Accent"
                      OnClick="HandleQuickEntryClick"
                      Style="margin-left: 12px;">
            Quick Entry
        </FluentButton>
    }
</FluentStack>

@code {
    [Parameter] public string MonthName { get; set; } = string.Empty;
    [Parameter] public int Year { get; set; }
    [Parameter] public EventCallback<int> OnNavigateMonth { get; set; }
    [Parameter] public EventCallback OnImportClick { get; set; }
    [Parameter] public EventCallback OnQuickEntryClick { get; set; }
    [Parameter] public bool ShowQuickEntry { get; set; }

    private async Task HandleQuickEntryClick()
    {
        if (ShowQuickEntry && OnQuickEntryClick.HasDelegate)
        {
            await OnQuickEntryClick.InvokeAsync();
        }
    }
}