@* ErrorAlert.razor - Reusable error display component with retry support and debug log download *@
@inject IExportDownloadService ExportDownloadService
@inject IToastService ToastService

@if (!string.IsNullOrEmpty(Message))
{
    <div class="error-alert">
        <div class="error-alert-content">
            <span class="error-alert-icon"><Icon Name="alert-triangle" Size="20" Class="icon-warning" /></span>
            <div class="error-alert-text">
                <span class="error-alert-message">@Message</span>
                @if (!string.IsNullOrEmpty(Details))
                {
                    <span class="error-alert-details">@Details</span>
                }
            </div>
        </div>
        <div class="error-alert-actions">
            @if (!string.IsNullOrEmpty(TraceId))
            {
                <button class="error-alert-debug-download" @onclick="HandleDownloadDebugLog" disabled="@_isDownloading" title="Download debug log for issue reporting">
                    @if (_isDownloading)
                    {
                        <span>Downloading...</span>
                    }
                    else
                    {
                        <span><Icon Name="download" Size="16" /> Debug Log</span>
                    }
                </button>
            }
            @if (OnRetry.HasDelegate)
            {
                <button class="error-alert-retry" @onclick="HandleRetry" disabled="@IsRetrying">
                    @if (IsRetrying)
                    {
                        <span>Retrying...</span>
                    }
                    else
                    {
                        <span><Icon Name="refresh" Size="16" /> Retry</span>
                    }
                </button>
            }
            @if (IsDismissible && OnDismiss.HasDelegate)
            {
                <button class="error-alert-dismiss" @onclick="HandleDismiss" title="Dismiss"><Icon Name="x" Size="16" /></button>
            }
        </div>
    </div>
}

@code {
    private bool _isDownloading;

    /// <summary>
    /// Gets or sets the error message to display.
    /// </summary>
    [Parameter]
    public string? Message { get; set; }

    /// <summary>
    /// Gets or sets additional error details (optional).
    /// </summary>
    [Parameter]
    public string? Details { get; set; }

    /// <summary>
    /// Gets or sets the traceId from the API error response. When set, a debug log download button is shown.
    /// </summary>
    [Parameter]
    public string? TraceId { get; set; }

    /// <summary>
    /// Gets or sets whether the alert can be dismissed.
    /// </summary>
    [Parameter]
    public bool IsDismissible { get; set; } = true;

    /// <summary>
    /// Gets or sets whether a retry operation is in progress.
    /// </summary>
    [Parameter]
    public bool IsRetrying { get; set; }

    /// <summary>
    /// Gets or sets the callback when retry is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnRetry { get; set; }

    /// <summary>
    /// Gets or sets the callback when dismiss is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnDismiss { get; set; }

    private async Task HandleDownloadDebugLog()
    {
        if (string.IsNullOrEmpty(TraceId))
        {
            return;
        }

        _isDownloading = true;
        try
        {
            var result = await ExportDownloadService.DownloadAsync($"api/v1/debug/logs/{TraceId}");
            if (!result.Success)
            {
                ToastService.ShowWarning(result.ErrorMessage ?? "Debug log unavailable.");
            }
        }
        finally
        {
            _isDownloading = false;
        }
    }

    private async Task HandleRetry()
    {
        await OnRetry.InvokeAsync();
    }

    private async Task HandleDismiss()
    {
        await OnDismiss.InvokeAsync();
    }
}
