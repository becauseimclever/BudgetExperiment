@* ChoroplethMap.razor - SVG choropleth map colored by spending data *@

@using BudgetExperiment.Contracts.Dtos

@if (Regions == null || Regions.Count == 0)
{
    <div class="choropleth-empty" role="status">
        <p>No location data available for the selected period.</p>
    </div>
}
else
{
    <div class="choropleth-container">
        <svg xmlns="http://www.w3.org/2000/svg"
             viewBox="0 0 960 600"
             role="img"
             aria-label="Spending by state map"
             class="choropleth-svg">
            <defs>
                @* Colorblind-friendly pattern fills keyed to spending intensity *@
                <pattern id="pattern-none" width="8" height="8" patternUnits="userSpaceOnUse">
                    <rect width="8" height="8" fill="#e5e7eb" />
                </pattern>
                <pattern id="pattern-low" width="8" height="8" patternUnits="userSpaceOnUse">
                    <rect width="8" height="8" fill="hsl(210, 65%, 82%)" />
                    <circle cx="4" cy="4" r="1.5" fill="hsl(210, 70%, 65%)" />
                </pattern>
                <pattern id="pattern-medium" width="8" height="8" patternUnits="userSpaceOnUse">
                    <rect width="8" height="8" fill="hsl(210, 70%, 62%)" />
                    <line x1="0" y1="0" x2="8" y2="8" stroke="hsl(210, 75%, 45%)" stroke-width="1.5" />
                </pattern>
                <pattern id="pattern-high" width="6" height="6" patternUnits="userSpaceOnUse">
                    <rect width="6" height="6" fill="hsl(210, 75%, 45%)" />
                    <line x1="0" y1="0" x2="6" y2="6" stroke="hsl(210, 80%, 30%)" stroke-width="1.5" />
                    <line x1="6" y1="0" x2="0" y2="6" stroke="hsl(210, 80%, 30%)" stroke-width="1.5" />
                </pattern>
            </defs>
            <g id="states">
                @foreach (var state in AllStates)
                {
                    var spending = GetRegionSpending(state.Code);
                    var fillColor = GetFillColor(spending);
                    var patternId = GetPatternId(spending);
                    var ariaLabel = GetAriaLabel(state.Code, state.Name, spending);

                    <path data-state="@state.Code"
                          d="@state.Path"
                          style="fill: @fillColor"
                          role="button"
                          tabindex="0"
                          aria-label="@ariaLabel"
                          @onclick="() => HandleClick(state.Code)"
                          @onkeydown="(e) => HandleKeyDown(e, state.Code)">
                        <title>@ariaLabel</title>
                    </path>
                    <path d="@state.Path"
                          style="fill: url(#@patternId)"
                          class="pattern-overlay"
                          aria-hidden="true"
                          pointer-events="none" />
                }
            </g>
        </svg>
    </div>
}

@code {
    /// <summary>
    /// Gets or sets the region spending data to display on the map.
    /// </summary>
    [Parameter]
    public IReadOnlyList<RegionSpendingDto>? Regions { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when a region is clicked.
    /// The parameter is the two-letter state code (e.g., "WA").
    /// </summary>
    [Parameter]
    public EventCallback<string> OnRegionClick { get; set; }

    private decimal maxSpending;

    /// <inheritdoc/>
    protected override void OnParametersSet()
    {
        maxSpending = Regions?.Count > 0
            ? Regions.Max(r => r.TotalSpending)
            : 0m;
    }

    private decimal GetRegionSpending(string stateCode)
    {
        if (Regions == null)
        {
            return 0m;
        }

        var regionCode = $"US-{stateCode}";
        return Regions.FirstOrDefault(r => r.RegionCode == regionCode)?.TotalSpending ?? 0m;
    }

    private string GetFillColor(decimal spending)
    {
        if (spending <= 0 || maxSpending <= 0)
        {
            return "#e5e7eb"; // neutral gray for no data
        }

        // Interpolate from light (hsl 210 60% 90%) to dark (hsl 210 80% 35%)
        var ratio = (double)(spending / maxSpending);
        var lightness = 90 - (int)(ratio * 55); // 90% → 35%
        var saturation = 60 + (int)(ratio * 20); // 60% → 80%
        return $"hsl(210, {saturation}%, {lightness}%)";
    }

    private string GetPatternId(decimal spending)
    {
        if (spending <= 0 || maxSpending <= 0)
        {
            return "pattern-none";
        }

        var ratio = spending / maxSpending;
        return ratio switch
        {
            >= 0.66m => "pattern-high",
            >= 0.33m => "pattern-medium",
            _ => "pattern-low",
        };
    }

    private string GetAriaLabel(string stateCode, string stateName, decimal spending)
    {
        if (spending > 0)
        {
            return $"{stateName}: ${spending:F2}";
        }

        return $"{stateName}: no spending data";
    }

    private async Task HandleClick(string stateCode)
    {
        if (OnRegionClick.HasDelegate)
        {
            await OnRegionClick.InvokeAsync(stateCode);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e, string stateCode)
    {
        if (e.Key is "Enter" or " ")
        {
            await HandleClick(stateCode);
        }
    }

    private static readonly IReadOnlyList<StateInfo> AllStates =
