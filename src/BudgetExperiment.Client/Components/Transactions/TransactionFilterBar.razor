@* TransactionFilterBar - Reusable filter bar for the unified transactions page *@

<div class="filter-section">
    <div class="filter-group">
        <label for="txnAccountFilter">Account:</label>
        <select id="txnAccountFilter" class="form-control" style="width: auto; min-width: 150px;"
                value="@AccountIdString" @onchange="OnAccountChanged">
            <option value="">All Accounts</option>
            @foreach (var account in Accounts)
            {
                <option value="@account.Id">@account.Name</option>
            }
        </select>
    </div>
    <div class="filter-group">
        <label for="txnCategoryFilter">Category:</label>
        <select id="txnCategoryFilter" class="form-control" style="width: auto; min-width: 150px;"
                value="@CategoryFilterValue" @onchange="OnCategoryChanged">
            <option value="">All Categories</option>
            <option value="uncategorized">Uncategorized</option>
            @foreach (var category in Categories)
            {
                <option value="@category.Id">@category.Name</option>
            }
        </select>
    </div>
    <div class="date-filter">
        <label for="txnFromDate">From:</label>
        <input type="date" id="txnFromDate" @bind="StartDate" @bind:after="OnFilterChanged" />
    </div>
    <div class="date-filter">
        <label for="txnToDate">To:</label>
        <input type="date" id="txnToDate" @bind="EndDate" @bind:after="OnFilterChanged" />
    </div>
    <div class="filter-group">
        <label for="txnDescriptionFilter">Description:</label>
        <input type="text" id="txnDescriptionFilter" class="form-control" style="width: 200px;"
               placeholder="Contains..."
               @bind="Filter.Description"
               @bind:after="OnFilterChanged" />
    </div>
    <div class="filter-group">
        <label for="txnMinAmount">Min $:</label>
        <input type="number" id="txnMinAmount" class="form-control" style="width: 100px;"
               step="0.01" min="0"
               @bind="Filter.MinAmount"
               @bind:after="OnFilterChanged" />
    </div>
    <div class="filter-group">
        <label for="txnMaxAmount">Max $:</label>
        <input type="number" id="txnMaxAmount" class="form-control" style="width: 100px;"
               step="0.01" min="0"
               @bind="Filter.MaxAmount"
               @bind:after="OnFilterChanged" />
    </div>
    <div class="filter-group">
        @if (ActiveFilterCount > 0)
        {
            <Badge Text="@ActiveFilterCount.ToString()" />
        }
        <Button Variant="ButtonVariant.Secondary" OnClick="OnClearFilters">Clear Filters</Button>
    </div>
</div>

@code {
    /// <summary>
    /// Gets or sets the filter DTO bound to this filter bar.
    /// </summary>
    [Parameter, EditorRequired]
    public UnifiedTransactionFilterDto Filter { get; set; } = new();

    /// <summary>
    /// Gets or sets the list of accounts for the dropdown.
    /// </summary>
    [Parameter]
    public IReadOnlyList<AccountDto> Accounts { get; set; } = [];

    /// <summary>
    /// Gets or sets the list of categories for the dropdown.
    /// </summary>
    [Parameter]
    public IReadOnlyList<BudgetCategoryDto> Categories { get; set; } = [];

    /// <summary>
    /// Gets or sets the number of active filters.
    /// </summary>
    [Parameter]
    public int ActiveFilterCount { get; set; }

    /// <summary>
    /// Gets or sets the callback when filters are applied.
    /// </summary>
    [Parameter]
    public EventCallback OnFiltersApplied { get; set; }

    /// <summary>
    /// Gets or sets the callback when filters are cleared.
    /// </summary>
    [Parameter]
    public EventCallback OnFiltersCleared { get; set; }

    private DateTime? StartDate
    {
        get => Filter.StartDate.HasValue ? Filter.StartDate.Value.ToDateTime(TimeOnly.MinValue) : null;
        set
        {
            Filter.StartDate = value.HasValue ? DateOnly.FromDateTime(value.Value) : null;
        }
    }

    private DateTime? EndDate
    {
        get => Filter.EndDate.HasValue ? Filter.EndDate.Value.ToDateTime(TimeOnly.MinValue) : null;
        set
        {
            Filter.EndDate = value.HasValue ? DateOnly.FromDateTime(value.Value) : null;
        }
    }

    private string AccountIdString => Filter.AccountId?.ToString() ?? string.Empty;

    private string CategoryFilterValue
    {
        get
        {
            if (Filter.Uncategorized == true)
            {
                return "uncategorized";
            }

            return Filter.CategoryId?.ToString() ?? string.Empty;
        }
    }

    private async Task OnAccountChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        Filter.AccountId = string.IsNullOrEmpty(value) ? null : Guid.Parse(value);
        await OnFilterChanged();
    }

    private async Task OnCategoryChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (value == "uncategorized")
        {
            Filter.Uncategorized = true;
            Filter.CategoryId = null;
        }
        else if (string.IsNullOrEmpty(value))
        {
            Filter.Uncategorized = null;
            Filter.CategoryId = null;
        }
        else
        {
            Filter.Uncategorized = null;
            Filter.CategoryId = Guid.Parse(value);
        }

        await OnFilterChanged();
    }

    private async Task OnFilterChanged()
    {
        await OnFiltersApplied.InvokeAsync();
    }

    private async Task OnClearFilters()
    {
        await OnFiltersCleared.InvokeAsync();
    }
}
