@* RulesPagination.razor - Server-side pagination controls for rules listing *@

@if (TotalPages > 1 || TotalCount > 0)
{
    <nav class="pagination-bar" aria-label="Rules pagination">
        <span class="pagination-info">
            Showing @PaginationStart&ndash;@PaginationEnd of @TotalCount rules
        </span>
        <div class="pagination-controls">
            <button class="pagination-prev" disabled="@(CurrentPage <= 1)" @onclick="HandlePrevious" aria-label="Previous page">&laquo;</button>
            @foreach (var pageNum in PageNumbers)
            {
                <button class="pagination-page @(pageNum == CurrentPage ? "active" : "")"
                        @onclick="@(() => HandlePageClick(pageNum))"
                        aria-label="@($"Go to page {pageNum}")"
                        aria-current="@(pageNum == CurrentPage ? "page" : null)">@pageNum</button>
            }
            <button class="pagination-next" disabled="@(CurrentPage >= TotalPages)" @onclick="HandleNext" aria-label="Next page">&raquo;</button>
            <select class="pagination-page-size" value="@PageSize" @onchange="HandlePageSizeChanged" aria-label="Page size">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
        </div>
    </nav>
}

@code {
    /// <summary>
    /// Gets or sets the current page number (1-based).
    /// </summary>
    [Parameter]
    public int CurrentPage { get; set; } = 1;

    /// <summary>
    /// Gets or sets the page size.
    /// </summary>
    [Parameter]
    public int PageSize { get; set; } = 25;

    /// <summary>
    /// Gets or sets the total count of matching items.
    /// </summary>
    [Parameter]
    public int TotalCount { get; set; }

    /// <summary>
    /// Gets or sets the total number of pages.
    /// </summary>
    [Parameter]
    public int TotalPages { get; set; }

    /// <summary>
    /// Gets or sets the callback when the page changes.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnPageChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback when the page size changes.
    /// </summary>
    [Parameter]
    public EventCallback<int> OnPageSizeChanged { get; set; }

    private int PaginationStart => TotalCount == 0 ? 0 : ((CurrentPage - 1) * PageSize) + 1;

    private int PaginationEnd => Math.Min(CurrentPage * PageSize, TotalCount);

    private IEnumerable<int> PageNumbers
    {
        get
        {
            const int maxVisible = 5;
            var start = Math.Max(1, CurrentPage - (maxVisible / 2));
            var end = Math.Min(TotalPages, start + maxVisible - 1);
            start = Math.Max(1, end - maxVisible + 1);

            for (var i = start; i <= end; i++)
            {
                yield return i;
            }
        }
    }

    private async Task HandlePrevious()
    {
        if (CurrentPage > 1)
        {
            await OnPageChanged.InvokeAsync(CurrentPage - 1);
        }
    }

    private async Task HandleNext()
    {
        if (CurrentPage < TotalPages)
        {
            await OnPageChanged.InvokeAsync(CurrentPage + 1);
        }
    }

    private async Task HandlePageClick(int page)
    {
        await OnPageChanged.InvokeAsync(page);
    }

    private async Task HandlePageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var newSize))
        {
            await OnPageSizeChanged.InvokeAsync(newSize);
        }
    }
}
