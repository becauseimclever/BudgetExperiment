@* TransactionTable.razor - Reusable transaction table component *@

@if ((Transactions == null || Transactions.Count == 0) && (Items == null || Items.Count == 0))
{
    <p class="empty-state empty-state-inline">@EmptyMessage</p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                @if (ShowDate)
                {
                    <th class="@SortableHeaderClass(SortDate)" @onclick="@(() => ToggleSort(SortDate))" aria-sort="@GetAriaSortValue(SortDate)">
                        Date <span class="sort-arrow">@GetSortArrow(SortDate)</span>
                    </th>
                }
                <th class="@SortableHeaderClass(SortDescription)" @onclick="@(() => ToggleSort(SortDescription))" aria-sort="@GetAriaSortValue(SortDescription)">
                    Description <span class="sort-arrow">@GetSortArrow(SortDescription)</span>
                </th>
                <th>Category</th>
                <th class="text-right @SortableHeaderClass(SortAmount)" @onclick="@(() => ToggleSort(SortAmount))" aria-sort="@GetAriaSortValue(SortAmount)">
                    Amount <span class="sort-arrow">@GetSortArrow(SortAmount)</span>
                </th>
                @if (ShowBalance)
                {
                    <th class="text-right @SortableHeaderClass(SortBalance)" @onclick="@(() => ToggleSort(SortBalance))" aria-sort="@GetAriaSortValue(SortBalance)">
                        Balance <span class="sort-arrow">@GetSortArrow(SortBalance)</span>
                    </th>
                }
                @if (ShowActions)
                {
                    <th class="actions">Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @if (Items != null && Items.Count > 0)
            {
                @foreach (var item in OrderedItems)
                {
                    <tr class="@GetRowClass(item)">
                        @if (ShowDate)
                        {
                            <td>
                                @item.Date.ToString("MMM d, yyyy")
                                @if (item.IsRecurring)
                                {
                                    <span class="row-indicator row-indicator-recurring" title="@(item.IsModified ? "Modified recurring transaction" : "Recurring transaction")"><Icon Name="recurring" Size="14" Class="icon-recurring" /></span>
                                }
                                @if (item.IsTransfer)
                                {
                                    <span class="row-indicator row-indicator-transfer" title="@GetTransferTooltip(item)"><Icon Name="transfer" Size="14" Class="icon-transfer" /></span>
                                }
                            </td>
                        }
                        <td>
                            @if (!ShowDate && item.IsRecurring)
                            {
                                <span class="row-indicator row-indicator-recurring" title="@(item.IsModified ? "Modified recurring transaction" : "Recurring transaction")"><Icon Name="recurring" Size="14" Class="icon-recurring" /></span>
                            }
                            @if (item.IsTransfer)
                            {
                                <span class="row-indicator row-indicator-transfer" title="@GetTransferTooltip(item)"><Icon Name="transfer" Size="14" Class="icon-transfer" /></span>
                            }
                            @item.Description
                            @if (item.IsModified)
                            {
                                <span class="badge-modified">modified</span>
                            }
                        </td>
                        <td>@(item.CategoryName ?? "-")</td>
                        <td class="text-right">
                            <MoneyDisplay Amount="@item.Amount.Amount" />
                        </td>
                        @if (ShowBalance)
                        {
                            <td class="text-right running-balance @(item.RunningBalance.Amount < 0 ? "balance-negative" : "")">
                                <MoneyDisplay Amount="@item.RunningBalance.Amount" />
                            </td>
                        }
                        @if (ShowActions)
                        {
                            <td class="actions">
                                @if (item.IsRecurring)
                                {
                                    <button class="btn btn-sm btn-success" @onclick="() => OnConfirmRecurring.InvokeAsync(item)" title="Confirm this occurrence">Confirm</button>
                                    <button class="btn btn-sm btn-primary" @onclick="() => OnEditRecurring.InvokeAsync(item)">Edit</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => OnSkipRecurring.InvokeAsync(item)">Skip</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-primary" @onclick="() => OnEditItem.InvokeAsync(item)">Edit</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => OnDeleteItem.InvokeAsync(item.Id)">Delete</button>
                                }
                            </td>
                        }
                    </tr>
                }
            }
            else
            {
                @foreach (var txn in OrderedTransactions)
                {
                    <tr class="@(txn.IsTransfer ? "row-transfer" : "")">
                        @if (ShowDate)
                        {
                            <td>
                                @txn.Date.ToString("MMM d, yyyy")
                                @if (txn.IsTransfer)
                                {
                                    <span class="row-indicator row-indicator-transfer" title="@GetTransactionTransferTooltip(txn)"><Icon Name="transfer" Size="14" Class="icon-transfer" /></span>
                                }
                            </td>
                        }
                        <td>
                            @if (!ShowDate && txn.IsTransfer)
                            {
                                <span class="row-indicator row-indicator-transfer" title="@GetTransactionTransferTooltip(txn)"><Icon Name="transfer" Size="14" Class="icon-transfer" /></span>
                            }
                            @txn.Description
                        </td>
                        <td>@(txn.CategoryName ?? "-")</td>
                        <td class="text-right">
                            <MoneyDisplay Amount="@txn.Amount.Amount" />
                        </td>
                        @if (ShowBalance)
                        {
                            <td class="text-right running-balance">-</td>
                        }
                        @if (ShowActions)
                        {
                            <td class="actions">
                                <button class="btn btn-sm btn-primary" @onclick="() => OnEdit.InvokeAsync(txn)">Edit</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => OnDelete.InvokeAsync(txn.Id)">Delete</button>
                            </td>
                        }
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    /// <summary>
    /// The list of transactions to display (legacy mode).
    /// </summary>
    [Parameter]
    public IReadOnlyList<TransactionDto> Transactions { get; set; } = new List<TransactionDto>();

    /// <summary>
    /// The list of unified transaction items to display (new mode - includes recurring).
    /// When provided, this takes precedence over Transactions.
    /// </summary>
    [Parameter]
    public IReadOnlyList<TransactionListItem>? Items { get; set; }

    /// <summary>
    /// Whether to show the date column. Default is false (useful when all transactions are for the same day).
    /// </summary>
    [Parameter]
    public bool ShowDate { get; set; } = false;

    /// <summary>
    /// Whether to show the actions column (Edit/Delete buttons). Default is false.
    /// </summary>
    [Parameter]
    public bool ShowActions { get; set; } = false;

    /// <summary>
    /// Whether to show the running balance column. Default is false.
    /// </summary>
    [Parameter]
    public bool ShowBalance { get; set; } = false;

    /// <summary>
    /// Message to display when there are no transactions.
    /// </summary>
    [Parameter]
    public string EmptyMessage { get; set; } = "No transactions found.";

    /// <summary>
    /// Callback when Edit button is clicked (legacy mode).
    /// </summary>
    [Parameter]
    public EventCallback<TransactionDto> OnEdit { get; set; }

    /// <summary>
    /// Callback when Delete button is clicked (legacy mode).
    /// </summary>
    [Parameter]
    public EventCallback<Guid> OnDelete { get; set; }

    /// <summary>
    /// Callback when Edit button is clicked for an item (new mode).
    /// </summary>
    [Parameter]
    public EventCallback<TransactionListItem> OnEditItem { get; set; }

    /// <summary>
    /// Callback when Delete button is clicked for an item (new mode).
    /// </summary>
    [Parameter]
    public EventCallback<Guid> OnDeleteItem { get; set; }

    /// <summary>
    /// Callback when Edit button is clicked for a recurring instance.
    /// </summary>
    [Parameter]
    public EventCallback<TransactionListItem> OnEditRecurring { get; set; }

    /// <summary>
    /// Callback when Skip button is clicked for a recurring instance.
    /// </summary>
    [Parameter]
    public EventCallback<TransactionListItem> OnSkipRecurring { get; set; }

    /// <summary>
    /// Callback when Confirm button is clicked for a recurring instance.
    /// </summary>
    [Parameter]
    public EventCallback<TransactionListItem> OnConfirmRecurring { get; set; }

    private const string SortDate = "Date";
    private const string SortDescription = "Description";
    private const string SortAmount = "Amount";
    private const string SortBalance = "Balance";

    private string _sortColumn = SortDate;
    private bool _sortDescending = true;

    private IEnumerable<TransactionDto> OrderedTransactions =>
        ApplySortTransactions(Transactions);

    private IEnumerable<TransactionListItem> OrderedItems =>
        Items == null
            ? Enumerable.Empty<TransactionListItem>()
            : ApplySortItems(Items);

    private void ToggleSort(string column)
    {
        if (_sortColumn == column)
        {
            _sortDescending = !_sortDescending;
        }
        else
        {
            _sortColumn = column;

            // Default direction: Date descending, everything else ascending
            _sortDescending = column == SortDate;
        }
    }

    private string SortableHeaderClass(string column)
    {
        var css = "sortable";
        if (_sortColumn == column)
        {
            css += " sorted";
        }

        return css;
    }

    private string GetSortArrow(string column)
    {
        if (_sortColumn != column)
        {
            return string.Empty;
        }

        return _sortDescending ? "\u25BC" : "\u25B2";
    }

    private string GetAriaSortValue(string column)
    {
        if (_sortColumn != column)
        {
            return "none";
        }

        return _sortDescending ? "descending" : "ascending";
    }

    private IEnumerable<TransactionListItem> ApplySortItems(IReadOnlyList<TransactionListItem> items)
    {
        return _sortColumn switch
        {
            SortDate => _sortDescending
                ? items.OrderByDescending(i => i.Date).ThenByDescending(i => i.CreatedAt ?? DateTime.MinValue)
                : items.OrderBy(i => i.Date).ThenBy(i => i.CreatedAt ?? DateTime.MinValue),
            SortDescription => _sortDescending
                ? items.OrderByDescending(i => i.Description, StringComparer.OrdinalIgnoreCase)
                : items.OrderBy(i => i.Description, StringComparer.OrdinalIgnoreCase),
            SortAmount => _sortDescending
                ? items.OrderByDescending(i => i.Amount.Amount)
                : items.OrderBy(i => i.Amount.Amount),
            SortBalance => _sortDescending
                ? items.OrderByDescending(i => i.RunningBalance.Amount)
                : items.OrderBy(i => i.RunningBalance.Amount),
            _ => items.OrderByDescending(i => i.Date).ThenByDescending(i => i.CreatedAt ?? DateTime.MinValue),
        };
    }

    private IEnumerable<TransactionDto> ApplySortTransactions(IReadOnlyList<TransactionDto> transactions)
    {
        return _sortColumn switch
        {
            SortDate => _sortDescending
                ? transactions.OrderByDescending(t => t.Date).ThenByDescending(t => t.CreatedAt)
                : transactions.OrderBy(t => t.Date).ThenBy(t => t.CreatedAt),
            SortDescription => _sortDescending
                ? transactions.OrderByDescending(t => t.Description, StringComparer.OrdinalIgnoreCase)
                : transactions.OrderBy(t => t.Description, StringComparer.OrdinalIgnoreCase),
            SortAmount => _sortDescending
                ? transactions.OrderByDescending(t => t.Amount.Amount)
                : transactions.OrderBy(t => t.Amount.Amount),
            _ => _sortDescending
                ? transactions.OrderByDescending(t => t.Date).ThenByDescending(t => t.CreatedAt)
                : transactions.OrderBy(t => t.Date).ThenBy(t => t.CreatedAt),
        };
    }

    private static string GetTransferTooltip(TransactionListItem item)
    {
        var direction = item.TransferDirection?.ToLowerInvariant() ?? "unknown";
        return direction == "source"
            ? "Transfer: Money sent to another account"
            : "Transfer: Money received from another account";
    }

    private static string GetTransactionTransferTooltip(TransactionDto txn)
    {
        var direction = txn.TransferDirection?.ToLowerInvariant() ?? "unknown";
        return direction == "source"
            ? "Transfer: Money sent to another account"
            : "Transfer: Money received from another account";
    }

    private static string GetRowClass(TransactionListItem item)
    {
        if (item.IsRecurring)
        {
            return "row-recurring";
        }

        if (item.IsTransfer)
        {
            return "row-transfer";
        }

        return string.Empty;
    }
}
