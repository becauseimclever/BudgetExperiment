@page "/reports"

@using BudgetExperiment.Client.Services

@inject IFeatureFlagClientService FeatureFlags

<PageTitle>Reports - Budget Experiment</PageTitle>

<div class="page-container">
    <PageHeader Title="Reports" />

    <p class="page-subtitle">View visualizations and insights about your spending</p>

    <div class="reports-grid">
        <a href="reports/categories" class="report-card">
            <div class="report-icon">
                <Icon Name="pie-chart" Size="48" />
            </div>
            <div class="report-content">
                <h3>Category Spending</h3>
                <p>See how your spending is distributed across categories for any month. Interactive donut chart with detailed breakdown.</p>
            </div>
            <div class="report-arrow">
                <Icon Name="chevron-right" Size="20" />
            </div>
        </a>

        <a href="reports/trends" class="report-card">
            <div class="report-icon">
                <Icon Name="bar-chart" Size="48" />
            </div>
            <div class="report-content">
                <h3>Monthly Trends</h3>
                <p>Track your spending patterns over time. Compare income and expenses across multiple months.</p>
            </div>
            <div class="report-arrow">
                <Icon Name="chevron-right" Size="20" />
            </div>
        </a>

        <a href="reports/budget-comparison" class="report-card">
            <div class="report-icon">
                <Icon Name="tag" Size="48" />
            </div>
            <div class="report-content">
                <h3>Budget vs. Actual</h3>
                <p>Compare your budgeted amounts against actual spending. Identify areas for improvement.</p>
            </div>
            <div class="report-arrow">
                <Icon Name="chevron-right" Size="20" />
            </div>
        </a>

        <a href="reports/dashboard" class="report-card">
            <div class="report-icon">
                <Icon Name="layers" Size="48" />
            </div>
            <div class="report-content">
                <h3>Financial Dashboard</h3>
                <p>Comprehensive overview combining treemap, waterfall, radar, and radial bar charts for your monthly finances.</p>
            </div>
            <div class="report-arrow">
                <Icon Name="chevron-right" Size="20" />
            </div>
        </a>

        @if (FeatureFlags.IsEnabled("Kaizen:Dashboard"))
        {
            <a href="reports/kaizen-dashboard" class="report-card">
                <div class="report-icon">
                    <Icon Name="trending-up" Size="48" />
                </div>
                <div class="report-content">
                    <h3>Kaizen Dashboard</h3>
                    <p>12-week spending trend by Kakeibo category.</p>
                </div>
                <div class="report-arrow">
                    <Icon Name="chevron-right" Size="20" />
                </div>
            </a>
        }
        @if (FeatureFlags.IsEnabled("Reports:CustomReportBuilder"))
        {
            <a href="reports/custom-builder" class="report-card">
                <div class="report-icon">
                    <Icon Name="layout" Size="48" />
                </div>
                <div class="report-content">
                    <h3>Custom Report Builder</h3>
                    <p>Compose your own report dashboard with drag-and-drop widgets.</p>
                </div>
                <div class="report-arrow">
                    <Icon Name="chevron-right" Size="20" />
                </div>
            </a>
        }
    </div>

    @if (!FeatureFlags.IsEnabled("Reports:CustomReportBuilder"))
    {
        <div class="alert alert-info mt-3" role="alert">
            Custom Reports Builder is currently disabled. Enable it in
            <a href="settings">Settings &gt; Feature Flags</a>.
        </div>
    }
</div>

