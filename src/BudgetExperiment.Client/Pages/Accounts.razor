@page "/accounts"

@implements IDisposable

@using BudgetExperiment.Client.ViewModels

@inject AccountsViewModel ViewModel
@inject CultureService Culture

<PageTitle>Accounts - Budget Experiment</PageTitle>

<div class="page-container">
    <PageHeader Title="Accounts">
        <Actions>
            <Button Variant="ButtonVariant.Primary" IconLeft="arrows-horizontal" OnClick="ViewModel.ShowTransfer">Transfer</Button>
            <Button Variant="ButtonVariant.Success" OnClick="ViewModel.ShowAddAccount">+ Add Account</Button>
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@ViewModel.ErrorMessage"
                OnRetry="ViewModel.RetryLoadAsync"
                OnDismiss="ViewModel.DismissError"
                IsRetrying="@ViewModel.IsRetrying" />

    @if (ViewModel.IsLoading)
    {
        <LoadingSpinner Message="Loading accounts..." />
    }
    else if (ViewModel.Accounts.Count == 0 && ViewModel.ErrorMessage == null)
    {
        <p class="empty-message">No accounts yet. Create one to get started!</p>
    }
    else if (ViewModel.ErrorMessage == null)
    {
        <div class="card-grid">
            @foreach (var account in ViewModel.Accounts)
            {
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-2">
                            <h3 class="card-title">@account.Name</h3>
                            <ScopeBadge Scope="@account.Scope" ShowLabel="false" />
                        </div>
                        <span class="text-secondary text-sm">@account.Type</span>
                        <div class="mt-3 text-sm">
                            <span class="text-secondary">Initial Balance:</span>
                            <span class="font-semibold ml-1 @(account.InitialBalance < 0 ? "text-expense" : "")">
                                @(account.InitialBalance.FormatCurrency(Culture.CurrentCulture))
                            </span>
                            <span class="text-disabled text-xs ml-1">(as of @account.InitialBalanceDate.ToString("M/d/yyyy"))</span>
                        </div>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Small" IconLeft="edit" OnClick="() => ViewModel.ShowEditAccount(account)" title="Edit account" />
                        <Button Variant="ButtonVariant.Primary" Size="ButtonSize.Small" IconLeft="arrows-horizontal" OnClick="() => ViewModel.ShowTransferFrom(account.Id)" title="Transfer from this account" />
                        <Button Variant="ButtonVariant.Primary" Size="ButtonSize.Small" OnClick="() => ViewModel.ViewAccount(account.Id)">Transactions</Button>
                        <Button Variant="ButtonVariant.Danger" Size="ButtonSize.Small" OnClick="() => ViewModel.DeleteAccount(account.Id)">Delete</Button>
                    </div>
                </div>
            }
        </div>
    }

    <Modal IsVisible="@ViewModel.ShowAddForm" Title="Add Account" OnClose="ViewModel.HideAddAccount">
        <AccountForm Model="@ViewModel.NewAccount"
                     OnSubmit="ViewModel.CreateAccountAsync"
                     OnCancel="ViewModel.HideAddAccount"
                     IsSubmitting="@ViewModel.IsSubmitting" />
    </Modal>

    <Modal IsVisible="@ViewModel.ShowEditForm" Title="Edit Account" OnClose="ViewModel.HideEditAccount">
        <AccountForm Model="@ViewModel.EditAccount"
                     OnSubmit="ViewModel.UpdateAccountAsync"
                     OnCancel="ViewModel.HideEditAccount"
                     SubmitButtonText="Save Changes"
                     IsSubmitting="@ViewModel.IsSubmitting" />
        <div class="alert alert-warning mt-4">
            <Icon Name="alert-triangle" Size="16" /> Changing initial balance will affect all calculated running balances.
        </div>
    </Modal>

    <Modal IsVisible="@ViewModel.ShowTransferDialog" Title="Transfer Between Accounts" OnClose="ViewModel.HideTransfer">
        <TransferDialog Accounts="@ViewModel.Accounts"
                        Model="@ViewModel.NewTransfer"
                        PreSelectedSourceAccountId="@ViewModel.PreSelectedSourceAccountId"
                        OnCreate="ViewModel.CreateTransferAsync"
                        OnCancel="ViewModel.HideTransfer" />
    </Modal>

    <ConfirmDialog IsVisible="@ViewModel.ShowDeleteConfirm"
                   Title="Delete Account"
                   Message="@($"Are you sure you want to delete '{ViewModel.DeletingAccount?.Name}'? This will also delete all transactions for this account.")"
                   ConfirmText="Delete"
                   IsProcessing="@ViewModel.IsDeleting"
                   OnConfirm="ViewModel.ConfirmDeleteAsync"
                   OnCancel="ViewModel.CancelDelete" />
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        ViewModel.OnStateChanged = () => InvokeAsync(StateHasChanged);
        await ViewModel.InitializeAsync();
    }

    public void Dispose()
    {
        ViewModel.OnStateChanged = null;
        ViewModel.Dispose();
    }
}
