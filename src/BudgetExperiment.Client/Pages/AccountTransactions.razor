@* AccountTransactions.razor - Legacy route redirect *@

@page "/accounts/{AccountId:guid}/transactions"

@inject NavigationManager Navigation

@* Legacy route redirect — bookmarks to /accounts/{id}/transactions now land on the unified Transactions page. *@

@code {
    /// <summary>
    /// Gets or sets the account ID from the route parameter.
    /// </summary>
    [Parameter]
    public Guid AccountId { get; set; }

    /// <inheritdoc />
    protected override void OnInitialized()
    {
        Navigation.NavigateTo($"/transactions?account={AccountId}", replace: true);
    }
}
