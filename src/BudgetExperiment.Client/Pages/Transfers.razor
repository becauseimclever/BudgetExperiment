@page "/transfers"

@implements IDisposable

@using BudgetExperiment.Client.ViewModels

@inject TransfersViewModel ViewModel

<PageTitle>Transfers - Budget Experiment</PageTitle>

<div class="page-container-wide">
    <PageHeader Title="Transfers">
        <Actions>
            <Button Variant="ButtonVariant.Success" OnClick="ViewModel.ShowCreateTransfer">+ New Transfer</Button>
        </Actions>
    </PageHeader>

    <div class="filter-section">
        <div class="filter-group">
            <label for="accountFilter">Account:</label>
            <select id="accountFilter" class="form-control" style="width: auto; min-width: 150px;" @bind="ViewModel.SelectedAccountId" @bind:after="ViewModel.ApplyFilters">
                <option value="">All Accounts</option>
                @foreach (var account in ViewModel.Accounts)
                {
                    <option value="@account.Id">@account.Name</option>
                }
            </select>
        </div>
        <div class="date-filter">
            <label for="fromDate">From:</label>
            <input type="date" id="fromDate" @bind="ViewModel.FromDate" @bind:after="ViewModel.ApplyFilters" />
        </div>
        <div class="date-filter">
            <label for="toDate">To:</label>
            <input type="date" id="toDate" @bind="ViewModel.ToDate" @bind:after="ViewModel.ApplyFilters" />
        </div>
        <Button Variant="ButtonVariant.Secondary" OnClick="ViewModel.ClearFilters">Clear Filters</Button>
    </div>

    @if (ViewModel.IsLoading)
    {
        <LoadingSpinner Message="Loading transfers..." />
    }
    else if (ViewModel.ErrorMessage != null)
    {
        <ErrorAlert Message="@ViewModel.ErrorMessage"
                    TraceId="@ViewModel.ErrorTraceId"
                    OnRetry="ViewModel.RetryLoadAsync"
                    OnDismiss="ViewModel.DismissError"
                    IsRetrying="@ViewModel.IsRetrying" />
    }
    
    @if (!ViewModel.IsLoading && ViewModel.FilteredTransfers.Count == 0 && ViewModel.ErrorMessage == null)
    {
        <div class="empty-state empty-state-inline">
            <p class="empty-state-description">
                @if (ViewModel.Transfers.Count == 0)
                {
                    <span>No transfers yet. Create one to move money between accounts!</span>
                }
                else
                {
                    <span>No transfers match the current filters.</span>
                }
            </p>
        </div>
    }
    else if (!ViewModel.IsLoading && ViewModel.ErrorMessage == null)
    {
        <div class="card">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>From</th>
                        <th>To</th>
                        <th class="text-right">Amount</th>
                        <th>Description</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var transfer in ViewModel.FilteredTransfers.OrderByDescending(t => t.Date))
                    {
                        <tr>
                            <td class="date">@transfer.Date.ToString("MMM d, yyyy")</td>
                            <td>@transfer.SourceAccountName</td>
                            <td>@transfer.DestinationAccountName</td>
                            <td class="text-right">
                                <MoneyDisplay Amount="@transfer.Amount" />
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(transfer.Description) ? "-" : transfer.Description)</td>
                            <td class="text-center" style="white-space: nowrap;">
                                <Button Variant="ButtonVariant.Primary" Size="ButtonSize.Small" OnClick="() => ViewModel.ShowEditTransfer(transfer)">Edit</Button>
                                <Button Variant="ButtonVariant.Danger" Size="ButtonSize.Small" OnClick="() => ViewModel.DeleteTransferAsync(transfer.TransferId)">Delete</Button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <Modal IsVisible="@ViewModel.ShowTransferDialog" Title="@(ViewModel.EditingTransfer == null ? "New Transfer" : "Edit Transfer")" OnClose="ViewModel.HideTransferDialog">
        @if (ViewModel.EditingTransfer == null)
        {
            <TransferDialog Accounts="@ViewModel.Accounts"
                            Model="@ViewModel.NewTransfer"
                            OnCreate="ViewModel.CreateTransferAsync"
                            OnCancel="ViewModel.HideTransferDialog" />
        }
        else
        {
            <TransferDialog Accounts="@ViewModel.Accounts"
                            Model="@ViewModel.NewTransfer"
                            UpdateModel="@ViewModel.EditTransfer"
                            IsEdit="true"
                            SourceAccountName="@ViewModel.EditingTransfer.SourceAccountName"
                            DestinationAccountName="@ViewModel.EditingTransfer.DestinationAccountName"
                            OnUpdate="ViewModel.UpdateTransferAsync"
                            OnCancel="ViewModel.HideTransferDialog" />
        }
    </Modal>
</div>

@code {
    /// <inheritdoc/>
    protected override async Task OnInitializedAsync()
    {
        ViewModel.OnStateChanged = () => InvokeAsync(StateHasChanged);
        await ViewModel.InitializeAsync();
    }

    /// <inheritdoc/>
    public void Dispose()
    {
        ViewModel.OnStateChanged = null;
        ViewModel.Dispose();
    }
}
