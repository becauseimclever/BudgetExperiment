@page "/recurring-transfers"

@implements IDisposable

@using BudgetExperiment.Client.ViewModels

@inject RecurringTransfersViewModel ViewModel

<PageTitle>Recurring Transfers - Budget Experiment</PageTitle>

<div class="page-container">
    <PageHeader Title="Recurring Transfers">
        <Actions>
            <Button Variant="ButtonVariant.Success" OnClick="ViewModel.OpenAddForm">+ Add Recurring Transfer</Button>
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@ViewModel.ErrorMessage"
                TraceId="@ViewModel.ErrorTraceId"
                IsDismissible="true"
                IsRetrying="@ViewModel.IsRetrying"
                OnRetry="ViewModel.RetryLoadAsync"
                OnDismiss="ViewModel.DismissError" />

    @if (ViewModel.IsLoading)
    {
        <LoadingSpinner Message="Loading recurring transfers..." />
    }
    else if (ViewModel.ErrorMessage != null)
    {
        @* Error is displayed by ErrorAlert above *@
    }
    else if (ViewModel.RecurringTransfers.Count == 0)
    {
        <EmptyState Title="No Recurring Transfers"
                   Description="Set up recurring transfers for automatic money movement between accounts."
                   Icon="repeat">
            <Button Variant="ButtonVariant.Primary" OnClick="ViewModel.OpenAddForm">Create Your First Recurring Transfer</Button>
        </EmptyState>
    }
    else
    {
        <div class="recurring-list">
            @foreach (var transfer in ViewModel.RecurringTransfers)
            {
                <div class="recurring-card @(transfer.IsActive ? "" : "inactive")">
                    <div class="recurring-card-header">
                        <div class="recurring-card-info">
                            <h3 class="recurring-card-title">@transfer.Description</h3>
                            <div class="badge-group">
                                <span class="badge-transfer-flow">
                                    <span class="badge badge-transfer-from">@transfer.SourceAccountName</span>
                                    <span class="badge-transfer-arrow">→</span>
                                    <span class="badge badge-transfer-to">@transfer.DestinationAccountName</span>
                                </span>
                                <span class="badge badge-frequency">@RecurringTransfersViewModel.FormatFrequency(transfer)</span>
                            </div>
                        </div>
                        <div class="recurring-card-amount positive">
                            @RecurringTransfersViewModel.FormatMoney(transfer.Amount)
                        </div>
                    </div>
                    <div class="detail-list">
                        <div class="detail-item">
                            <span class="detail-label">Next:</span>
                            <span class="detail-value">@transfer.NextOccurrence.ToString("MMM d, yyyy")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Started:</span>
                            <span class="detail-value">@transfer.StartDate.ToString("MMM d, yyyy")</span>
                        </div>
                        @if (transfer.EndDate.HasValue)
                        {
                            <div class="detail-item">
                                <span class="detail-label">Ends:</span>
                                <span class="detail-value">@transfer.EndDate.Value.ToString("MMM d, yyyy")</span>
                            </div>
                        }
                        <div class="detail-item">
                            <span class="detail-label">Status:</span>
                            <span class="badge-status @(transfer.IsActive ? "badge-status-active" : "badge-status-paused")">
                                @(transfer.IsActive ? "Active" : "Paused")
                            </span>
                        </div>
                    </div>
                    <div class="recurring-card-actions">
                        @if (transfer.IsActive)
                        {
                            <button class="btn-action" @onclick="() => ViewModel.SkipNextAsync(transfer)" title="Skip next occurrence">
                                <Icon Name="skip-forward" Size="16" /> Skip
                            </button>
                            <button class="btn-action" @onclick="() => ViewModel.PauseAsync(transfer)" title="Pause">
                                <Icon Name="pause" Size="16" /> Pause
                            </button>
                        }
                        else
                        {
                            <button class="btn-action btn-action-resume" @onclick="() => ViewModel.ResumeAsync(transfer)" title="Resume">
                                <Icon Name="play" Size="16" /> Resume
                            </button>
                        }
                        <button class="btn-action btn-action-edit" @onclick="() => ViewModel.OpenEditForm(transfer)" title="Edit">
                            <Icon Name="edit" Size="16" /> Edit
                        </button>
                        <button class="btn-action btn-action-delete" @onclick="() => ViewModel.OpenDeleteConfirm(transfer)" title="Delete">
                            <Icon Name="trash" Size="16" /> Delete
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    <Modal IsVisible="@ViewModel.ShowAddForm" Title="Add Recurring Transfer" OnClose="ViewModel.HideForm">
        <RecurringTransferForm Model="@ViewModel.NewRecurring"
                               OnSubmit="ViewModel.CreateRecurringAsync"
                               OnCancel="ViewModel.HideForm"
                               IsSubmitting="@ViewModel.IsSubmitting" />
    </Modal>

    <Modal IsVisible="@ViewModel.ShowEditForm" Title="Edit Recurring Transfer" OnClose="ViewModel.HideForm">
        <EditRecurringTransferForm Model="@ViewModel.EditModel"
                                   OnSubmit="ViewModel.UpdateRecurringAsync"
                                   OnCancel="ViewModel.HideForm"
                                   IsSubmitting="@ViewModel.IsSubmitting" />
    </Modal>

    <ConfirmDialog IsVisible="@ViewModel.ShowDeleteConfirm"
                   Title="Delete Recurring Transfer"
                   Message="@($"Are you sure you want to delete '{ViewModel.DeletingTransfer?.Description}'? Future occurrences will no longer be scheduled.")"
                   ConfirmText="Delete"
                   IsProcessing="@ViewModel.IsDeleting"
                   OnConfirm="ViewModel.ConfirmDeleteAsync"
                   OnCancel="ViewModel.CancelDelete" />
</div>

@code {
    /// <inheritdoc/>
    protected override async Task OnInitializedAsync()
    {
        ViewModel.OnStateChanged = () => InvokeAsync(StateHasChanged);
        await ViewModel.InitializeAsync();
    }

    /// <inheritdoc/>
    public void Dispose()
    {
        ViewModel.OnStateChanged = null;
        ViewModel.Dispose();
    }
}
