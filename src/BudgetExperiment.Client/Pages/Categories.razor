@page "/categories"

@implements IDisposable

@using BudgetExperiment.Client.ViewModels

@inject CategoriesViewModel ViewModel

<PageTitle>Budget Categories - Budget Experiment</PageTitle>

<div class="page-container">
    <PageHeader Title="Budget Categories">
        <Actions>
            <Button Variant="ButtonVariant.Success" OnClick="ViewModel.OpenAddCategory">+ Add Category</Button>
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@ViewModel.ErrorMessage"
                OnRetry="ViewModel.RetryLoadAsync"
                OnDismiss="ViewModel.DismissError"
                IsRetrying="@ViewModel.IsRetrying" />

    @if (ViewModel.IsLoading)
    {
        <LoadingSpinner Message="Loading categories..." />
    }
    else if (ViewModel.Categories.Count == 0 && ViewModel.ErrorMessage == null)
    {
        <p class="empty-message">No categories yet. Create one to organize your budget!</p>
    }
    else if (ViewModel.ErrorMessage == null)
    {
        @if (ViewModel.ExpenseCategories.Count > 0)
        {
            <div class="category-section">
                <h3 class="category-section-title">
                    <span class="text-expense">Expense Categories</span>
                    <span class="badge badge-secondary">@ViewModel.ExpenseCategories.Count</span>
                </h3>
                <div class="card-grid">
                    @foreach (var category in ViewModel.ExpenseCategories)
                    {
                        <CategoryCard Category="@category"
                                      OnEdit="ViewModel.OpenEditCategory"
                                      OnDelete="ViewModel.ConfirmDeleteCategory"
                                      OnActivate="ViewModel.ActivateCategoryAsync"
                                      OnDeactivate="ViewModel.DeactivateCategoryAsync" />
                    }
                </div>
            </div>
        }
        
        @if (ViewModel.IncomeCategories.Count > 0)
        {
            <div class="category-section">
                <h3 class="category-section-title">
                    <span class="text-income">Income Categories</span>
                    <span class="badge badge-secondary">@ViewModel.IncomeCategories.Count</span>
                </h3>
                <div class="card-grid">
                    @foreach (var category in ViewModel.IncomeCategories)
                    {
                        <CategoryCard Category="@category"
                                      OnEdit="ViewModel.OpenEditCategory"
                                      OnDelete="ViewModel.ConfirmDeleteCategory"
                                      OnActivate="ViewModel.ActivateCategoryAsync"
                                      OnDeactivate="ViewModel.DeactivateCategoryAsync" />
                    }
                </div>
            </div>
        }
        
        @if (ViewModel.TransferCategories.Count > 0)
        {
            <div class="category-section">
                <h3 class="category-section-title">
                    <span class="text-secondary">Transfer Categories</span>
                    <span class="badge badge-secondary">@ViewModel.TransferCategories.Count</span>
                </h3>
                <div class="card-grid">
                    @foreach (var category in ViewModel.TransferCategories)
                    {
                        <CategoryCard Category="@category"
                                      OnEdit="ViewModel.OpenEditCategory"
                                      OnDelete="ViewModel.ConfirmDeleteCategory"
                                      OnActivate="ViewModel.ActivateCategoryAsync"
                                      OnDeactivate="ViewModel.DeactivateCategoryAsync" />
                    }
                </div>
            </div>
        }
    }

    <Modal IsVisible="@ViewModel.ShowAddForm" Title="Add Category" OnClose="ViewModel.CloseAddCategory">
        <CategoryForm Model="@ViewModel.NewCategory"
                      OnSubmit="ViewModel.CreateCategoryAsync"
                      OnCancel="ViewModel.CloseAddCategory"
                      IsSubmitting="@ViewModel.IsSubmitting" />
    </Modal>

    <Modal IsVisible="@ViewModel.ShowEditForm" Title="Edit Category" OnClose="ViewModel.CloseEditCategory">
        <CategoryForm Model="@ViewModel.EditCategory"
                      OnSubmit="ViewModel.UpdateCategoryAsync"
                      OnCancel="ViewModel.CloseEditCategory"
                      SubmitButtonText="Save Changes"
                      IsSubmitting="@ViewModel.IsSubmitting"
                      ShowSortOrder="true"
                      SortOrder="@ViewModel.EditSortOrder"
                      SortOrderChanged="@(value => ViewModel.EditSortOrder = value)" />
    </Modal>

    <ConfirmDialog IsVisible="@ViewModel.ShowDeleteConfirm"
                   Title="Delete Category"
                   Message="@($"Are you sure you want to delete '{ViewModel.DeletingCategory?.Name}'? This action cannot be undone.")"
                   ConfirmText="Delete"
                   IsProcessing="@ViewModel.IsDeleting"
                   OnConfirm="ViewModel.DeleteCategoryAsync"
                   OnCancel="ViewModel.CancelDelete" />
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        ViewModel.OnStateChanged = () => InvokeAsync(StateHasChanged);
        await ViewModel.InitializeAsync();
    }

    public void Dispose()
    {
        ViewModel.OnStateChanged = null;
        ViewModel.Dispose();
    }
}

