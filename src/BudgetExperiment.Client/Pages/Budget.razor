@page "/budget"

@implements IDisposable

@using BudgetExperiment.Client.ViewModels

@inject BudgetViewModel ViewModel

<PageTitle>Budget Overview - Budget Experiment</PageTitle>

<div class="page-container">
    <PageHeader Title="Budget Overview">
        <Actions>
            <div class="month-navigation">
                <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Small" IconLeft="chevron-left" OnClick="ViewModel.PreviousMonthAsync" title="Previous month" />
                <span class="current-month">@ViewModel.CurrentDate.ToString("MMMM yyyy")</span>
                <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Small" IconLeft="chevron-right" OnClick="ViewModel.NextMonthAsync" title="Next month" />
            </div>
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@ViewModel.ErrorMessage"
                OnRetry="ViewModel.RetryLoadAsync"
                OnDismiss="ViewModel.DismissError"
                IsRetrying="@ViewModel.IsRetrying" />

    @if (ViewModel.IsLoading)
    {
        <LoadingSpinner Message="Loading budget..." />
    }
    else if (ViewModel.Summary == null && ViewModel.ErrorMessage == null)
    {
        <p class="empty-message">No budget data available. Set up budget goals in Categories.</p>
    }
    else if (ViewModel.ErrorMessage == null && ViewModel.Summary != null)
    {
        @* Summary Card *@
        <div class="budget-summary-card">
            <h3>Monthly Summary</h3>
            <div class="summary-stats">
                <div class="summary-stat">
                    <span class="stat-label">Total Budgeted</span>
                    <span class="stat-value">
                        <MoneyDisplay Amount="@ViewModel.Summary.TotalBudgeted.Amount" CurrencyCode="@ViewModel.Summary.TotalBudgeted.Currency" />
                    </span>
                </div>
                <div class="summary-stat">
                    <span class="stat-label">Total Spent</span>
                    <span class="stat-value text-expense">
                        <MoneyDisplay Amount="@ViewModel.Summary.TotalSpent.Amount" CurrencyCode="@ViewModel.Summary.TotalSpent.Currency" />
                    </span>
                </div>
                <div class="summary-stat">
                    <span class="stat-label">Remaining</span>
                    <span class="stat-value @(ViewModel.Summary.TotalRemaining.Amount >= 0 ? "text-income" : "text-expense")">
                        <MoneyDisplay Amount="@ViewModel.Summary.TotalRemaining.Amount" CurrencyCode="@ViewModel.Summary.TotalRemaining.Currency" />
                    </span>
                </div>
            </div>
            
            <BudgetProgressBar PercentUsed="@ViewModel.Summary.OverallPercentUsed" 
                               Status="@ViewModel.OverallStatus" />
            
            <div class="summary-status-counts">
                @if (ViewModel.Summary.CategoriesOnTrack > 0)
                {
                    <span class="status-count status-success">
                        ✓ @ViewModel.Summary.CategoriesOnTrack on track
                    </span>
                }
                @if (ViewModel.Summary.CategoriesWarning > 0)
                {
                    <span class="status-count status-warning">
                        ⚠️ @ViewModel.Summary.CategoriesWarning warning
                    </span>
                }
                @if (ViewModel.Summary.CategoriesOverBudget > 0)
                {
                    <span class="status-count status-danger">
                        🔴 @ViewModel.Summary.CategoriesOverBudget over budget
                    </span>
                }
                @if (ViewModel.Summary.CategoriesNoBudgetSet > 0)
                {
                    <span class="status-count status-no-budget">
                        ⬚ @ViewModel.Summary.CategoriesNoBudgetSet no budget
                    </span>
                }
            </div>
        </div>

        @* Category Progress *@
        @if (ViewModel.Summary.CategoryProgress.Count > 0)
        {
            <div class="budget-categories-section">
                <h3>By Category</h3>
                <div class="card-grid">
                    @foreach (var progress in ViewModel.Summary.CategoryProgress.OrderByDescending(p => p.PercentUsed))
                    {
                        <CategoryBudgetCard Progress="@progress"
                                            ShowEditButton="true"
                                            OnEditGoal="ViewModel.ShowEditGoal" />
                    }
                </div>
            </div>
        }
        else
        {
            <EmptyState Title="No budget goals set"
                       Description="@($"Set budget goals for {ViewModel.CurrentDate:MMMM yyyy} in Categories.")">
                <Button Variant="ButtonVariant.Primary" IconLeft="tag" OnClick="ViewModel.NavigateToCategories">Manage Categories</Button>
            </EmptyState>
        }
    }

    <Modal IsVisible="@ViewModel.ShowEditGoalModal" Title="@ViewModel.ModalTitle" OnClose="ViewModel.HideEditGoal">
        <div class="form-group">
            <label class="form-label">Category</label>
            <p class="form-static">@ViewModel.EditingProgress?.CategoryName</p>
        </div>
        <div class="form-group">
            <label class="form-label">Month</label>
            <p class="form-static">@ViewModel.CurrentDate.ToString("MMMM yyyy")</p>
        </div>
        <div class="form-group">
            <label for="targetAmount" class="form-label">Budget Amount:</label>
            <div class="input-group">
                <span class="input-group-text">$</span>
                <input id="targetAmount" 
                       type="number" 
                       class="form-control"
                       step="0.01"
                       min="0"
                       @bind="ViewModel.EditTargetAmount"
                       placeholder="0.00" />
            </div>
        </div>
        <div class="form-actions form-actions-right">
            @if (!ViewModel.IsCreatingNewGoal)
            {
                <button type="button" class="btn btn-danger" @onclick="ViewModel.DeleteGoalAsync" disabled="@ViewModel.IsSubmitting">
                    Delete Goal
                </button>
            }
            <button type="button" class="btn btn-secondary" @onclick="ViewModel.HideEditGoal" disabled="@ViewModel.IsSubmitting">
                Cancel
            </button>
            <button type="button" class="btn btn-primary" @onclick="ViewModel.SaveGoalAsync" disabled="@ViewModel.IsSubmitting">
                @if (ViewModel.IsSubmitting)
                {
                    <span>Saving...</span>
                }
                else
                {
                    <span>Save</span>
                }
            </button>
        </div>
    </Modal>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        ViewModel.OnStateChanged = () => InvokeAsync(StateHasChanged);
        await ViewModel.InitializeAsync();
    }

    public void Dispose()
    {
        ViewModel.OnStateChanged = null;
        ViewModel.Dispose();
    }
}
