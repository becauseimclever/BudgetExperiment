@page "/recurring"

@implements IDisposable

@using BudgetExperiment.Client.ViewModels

@inject RecurringViewModel ViewModel

<PageTitle>Recurring Transactions - Budget Experiment</PageTitle>

<div class="page-container">
    <PageHeader Title="Recurring Transactions">
        <Actions>
            <Button Variant="ButtonVariant.Success" OnClick="ViewModel.OpenAddForm">+ Add Recurring</Button>
        </Actions>
    </PageHeader>

    <ErrorAlert Message="@ViewModel.ErrorMessage"
                IsDismissible="true"
                IsRetrying="@ViewModel.IsRetrying"
                OnRetry="ViewModel.RetryLoadAsync"
                OnDismiss="ViewModel.DismissError" />

    @if (ViewModel.IsLoading)
    {
        <LoadingSpinner Message="Loading recurring transactions..." />
    }
    else if (ViewModel.ErrorMessage != null)
    {
        @* Error is displayed by ErrorAlert above *@
    }
    else if (ViewModel.RecurringTransactions.Count == 0)
    {
        <EmptyState Title="No Recurring Transactions"
                   Description="Set up recurring transactions for bills, income, or regular expenses."
                   Icon="refresh">
            <Button Variant="ButtonVariant.Primary" OnClick="ViewModel.OpenAddForm">Create Your First Recurring Transaction</Button>
        </EmptyState>
    }
    else
    {
        <div class="recurring-list">
            @foreach (var recurring in ViewModel.RecurringTransactions)
            {
                <div class="recurring-card @(recurring.IsActive ? "" : "inactive")">
                    <div class="recurring-card-header">
                        <div class="recurring-card-info">
                            <h3 class="recurring-card-title">@recurring.Description</h3>
                            <div class="badge-group">
                                <span class="badge badge-account">@recurring.AccountName</span>
                                <span class="badge badge-frequency">@RecurringViewModel.FormatFrequency(recurring)</span>
                                @if (recurring.CategoryId.HasValue)
                                {
                                    <span class="badge badge-category">@recurring.CategoryId.ToString()![..8]</span>
                                }
                            </div>
                        </div>
                        <div class="recurring-card-amount @(recurring.Amount.Amount >= 0 ? "positive" : "negative")">
                            @RecurringViewModel.FormatMoney(recurring.Amount)
                        </div>
                    </div>
                    <div class="detail-list">
                        <div class="detail-item">
                            <span class="detail-label">Next:</span>
                            <span class="detail-value">@recurring.NextOccurrence.ToString("MMM d, yyyy")</span>
                        </div>
                        <div class="detail-item">
                            <span class="detail-label">Started:</span>
                            <span class="detail-value">@recurring.StartDate.ToString("MMM d, yyyy")</span>
                        </div>
                        @if (recurring.EndDate.HasValue)
                        {
                            <div class="detail-item">
                                <span class="detail-label">Ends:</span>
                                <span class="detail-value">@recurring.EndDate.Value.ToString("MMM d, yyyy")</span>
                            </div>
                        }
                        <div class="detail-item">
                            <span class="detail-label">Status:</span>
                            <span class="badge-status @(recurring.IsActive ? "badge-status-active" : "badge-status-paused")">
                                @(recurring.IsActive ? "Active" : "Paused")
                            </span>
                        </div>
                    </div>
                    <div class="recurring-card-actions">
                        @if (recurring.IsActive)
                        {
                            <button class="btn-action" @onclick="() => ViewModel.SkipNextAsync(recurring)" title="Skip next occurrence">
                                <Icon Name="skip-forward" Size="16" /> Skip
                            </button>
                            <button class="btn-action" @onclick="() => ViewModel.PauseAsync(recurring)" title="Pause">
                                <Icon Name="pause" Size="16" /> Pause
                            </button>
                        }
                        else
                        {
                            <button class="btn-action btn-action-resume" @onclick="() => ViewModel.ResumeAsync(recurring)" title="Resume">
                                <Icon Name="play" Size="16" /> Resume
                            </button>
                        }
                        <button class="btn-action" @onclick="() => ViewModel.OpenImportPatterns(recurring)" title="Import Patterns">
                            <Icon Name="filter" Size="16" /> Patterns
                        </button>
                        <button class="btn-action btn-action-edit" @onclick="() => ViewModel.OpenEditForm(recurring)" title="Edit">
                            <Icon Name="edit" Size="16" /> Edit
                        </button>
                        <button class="btn-action btn-action-delete" @onclick="() => ViewModel.OpenDeleteConfirm(recurring)" title="Delete">
                            <Icon Name="trash" Size="16" /> Delete
                        </button>
                    </div>
                </div>
            }
        </div>
    }

    <Modal IsVisible="@ViewModel.ShowAddForm" Title="Add Recurring Transaction" OnClose="ViewModel.HideForm">
        <RecurringTransactionForm Model="@ViewModel.NewRecurring"
                                   Categories="@ViewModel.Categories"
                                   OnSubmit="ViewModel.CreateRecurringAsync"
                                   OnCancel="ViewModel.HideForm"
                                   IsSubmitting="@ViewModel.IsSubmitting" />
    </Modal>

    <Modal IsVisible="@ViewModel.ShowEditForm" Title="Edit Recurring Transaction" OnClose="ViewModel.HideForm">
        <EditRecurringForm Model="@ViewModel.EditModel"
                           Categories="@ViewModel.Categories"
                           OnSubmit="ViewModel.UpdateRecurringAsync"
                           OnCancel="ViewModel.HideForm"
                           IsSubmitting="@ViewModel.IsSubmitting" />
    </Modal>

    <ConfirmDialog IsVisible="@ViewModel.ShowDeleteConfirm"
                   Title="Delete Recurring Transaction"
                   Message="@($"Are you sure you want to delete '{ViewModel.DeletingRecurring?.Description}'? Future occurrences will no longer be scheduled.")"
                   ConfirmText="Delete"
                   IsProcessing="@ViewModel.IsDeleting"
                   OnConfirm="ViewModel.ConfirmDeleteAsync"
                   OnCancel="ViewModel.CancelDelete" />

    <ImportPatternsDialog IsVisible="@ViewModel.ShowImportPatterns"
                          RecurringTransactionId="@ViewModel.ImportPatternsRecurringId"
                          RecurringDescription="@ViewModel.ImportPatternsDescription"
                          OnSaved="ViewModel.HandleImportPatternsSaved"
                          OnCancel="ViewModel.HideImportPatterns" />
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        ViewModel.OnStateChanged = () => InvokeAsync(StateHasChanged);
        await ViewModel.InitializeAsync();
    }

    public void Dispose()
    {
        ViewModel.OnStateChanged = null;
        ViewModel.Dispose();
    }
}
