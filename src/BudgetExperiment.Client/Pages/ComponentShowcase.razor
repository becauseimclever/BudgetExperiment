        new RadarDataSeries("Budgeted", new decimal[] { 1500m, 500m, 300m, 200m, 150m }),
        new RadarDataSeries("Actual", new decimal[] { 1250m, 620m, 310m, 189m, 95m }),
    ];

    private readonly HeatmapDataPoint[][] heatmapData = BuildShowcaseHeatmap();

    private static HeatmapDataPoint[][] BuildShowcaseHeatmap()
    {
        decimal[][] amounts =
        [
            [120m, 45m, 200m, 90m],
            [60m, 180m, 30m, 150m],
            [200m, 75m, 120m, 60m],
            [45m, 310m, 80m, 175m],
            [250m, 100m, 400m, 280m],
            [180m, 520m, 350m, 410m],
            [90m, 60m, 150m, 100m],
        ];
        return amounts
            .Select((row, day) => row.Select((amt, week) => new HeatmapDataPoint(day, week, amt, (int)(amt / 30))).ToArray())
            .ToArray();
    }
