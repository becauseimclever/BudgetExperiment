@page "/onboarding"
@layout EmptyLayout

@using BudgetExperiment.Client.Components.Onboarding
@using BudgetExperiment.Client.ViewModels

@inject OnboardingViewModel ViewModel
@inject NavigationManager NavigationManager

<PageTitle>Welcome - Budget Experiment</PageTitle>

<div class="onboarding-overlay">
    <div class="onboarding-card">
        @* Step indicators *@
        <div class="onboarding-steps" role="progressbar" aria-valuenow="@ViewModel.CurrentStep" aria-valuemin="1" aria-valuemax="5">
            @for (var i = 1; i <= 5; i++)
            {
                var stepClass = i < ViewModel.CurrentStep ? "completed" : (i == ViewModel.CurrentStep ? "active" : "");
                <div class="onboarding-step-dot @stepClass" aria-hidden="true"></div>
            }
        </div>

        @switch (ViewModel.CurrentStep)
        {
            case 1:
                <div class="onboarding-header">
                    <h1>Welcome to Budget Experiment</h1>
                    <p>Let's set up a couple of preferences so everything works the way you expect.</p>
                </div>

                <div class="onboarding-actions">
                    <button class="btn-skip" @onclick="ViewModel.SkipOnboardingAsync">Skip setup</button>
                    <button class="btn btn-primary" @onclick="ViewModel.NextStep">Get Started</button>
                </div>
                break;

            case 2:
                <div class="onboarding-header">
                    <h1>Choose Your Currency</h1>
                    <p>All monetary values in the app will display in this currency.</p>
                </div>

                <div class="onboarding-field">
                    <label for="currency-search">Currency</label>
                    <div class="currency-search-wrapper">
                        <input id="currency-search"
                               type="text"
                               class="form-control"
                               placeholder="Search currencies..."
                               @bind="ViewModel.CurrencySearch"
                               @bind:event="oninput"
                               @onfocus="() => ViewModel.ShowCurrencyDropdown = true"
                               autocomplete="off" />
                        @if (ViewModel.ShowCurrencyDropdown)
                        {
                            <div class="currency-dropdown">
                                @foreach (var currency in ViewModel.FilteredCurrencies)
                                {
                                    <button class="currency-option @(ViewModel.SelectedCurrency == currency.Code ? "selected" : "")"
                                            @onclick="() => ViewModel.SelectCurrency(currency)">
                                        <span class="currency-code">@currency.Code</span>
                                        <span class="currency-symbol">@currency.Symbol</span>
                                        <span class="currency-name">@currency.Name</span>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(ViewModel.SelectedCurrency))
                    {
                        var selected = CurrencyList.Currencies.FirstOrDefault(c => c.Code == ViewModel.SelectedCurrency);
                        if (selected != null)
                        {
                            <div class="selected-currency" @onclick="() => { ViewModel.ShowCurrencyDropdown = true; ViewModel.CurrencySearch = string.Empty; }">
                                <strong>@selected.Code</strong> — @selected.Symbol @selected.Name
                            </div>
                        }
                    }
                </div>

                <div class="onboarding-actions">
                    <button class="btn-skip" @onclick="ViewModel.SkipOnboardingAsync">Skip</button>
                    <div>
                        <button class="btn btn-secondary" @onclick="ViewModel.PreviousStep">Back</button>
                        <button class="btn btn-primary" @onclick="ViewModel.NextStep">Next</button>
                    </div>
                </div>
                break;

            case 3:
                <div class="onboarding-header">
                    <h1>First Day of the Week</h1>
                    <p>Choose which day your week starts on. This affects calendar views and weekly reports.</p>
                </div>

                <div class="onboarding-field">
                    <label>Week starts on</label>
                    <div class="dow-toggle-group">
                        <button class="dow-toggle @(ViewModel.SelectedFirstDay == DayOfWeek.Sunday ? "active" : "")"
                                @onclick="() => ViewModel.SelectedFirstDay = DayOfWeek.Sunday">
                            Sunday
                        </button>
                        <button class="dow-toggle @(ViewModel.SelectedFirstDay == DayOfWeek.Monday ? "active" : "")"
                                @onclick="() => ViewModel.SelectedFirstDay = DayOfWeek.Monday">
                            Monday
                        </button>
                    </div>
                </div>

                <div class="onboarding-actions">
                    <button class="btn-skip" @onclick="ViewModel.SkipOnboardingAsync">Skip</button>
                    <div>
                        <button class="btn btn-secondary" @onclick="ViewModel.PreviousStep">Back</button>
                        <button class="btn btn-primary" @onclick="ViewModel.NextStep">Next</button>
                    </div>
                </div>
                break;

            case 4:
                <div class="onboarding-header">
                    <h1>You're Almost There!</h1>
                    <p>Here's a summary of your choices. You can change these anytime in Settings.</p>
                </div>

                <div class="onboarding-summary">
                    <div class="onboarding-summary-item">
                        <span class="onboarding-summary-label">Currency</span>
                        <span class="onboarding-summary-value">@ViewModel.GetCurrencyDisplay()</span>
                    </div>
                    <div class="onboarding-summary-item">
                        <span class="onboarding-summary-label">Week starts on</span>
                        <span class="onboarding-summary-value">@ViewModel.SelectedFirstDay</span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
                {
                    <div class="alert alert-danger">@ViewModel.ErrorMessage</div>
                }

                <div class="onboarding-actions">
                    <button class="btn btn-secondary" @onclick="ViewModel.PreviousStep">Back</button>
                    <button class="btn btn-primary" @onclick="ViewModel.NextStep">Next →</button>
                </div>
                break;

            case 5:
                <KakeiboSetupStep OnComplete="ViewModel.CompleteOnboardingAsync"
                                  OnBack="ViewModel.PreviousStep" />
                break;
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        ViewModel.OnStateChanged = () => InvokeAsync(StateHasChanged);

        // Support ?step=kakeibo query parameter for post-migration banner redirect
        var uri = new Uri(NavigationManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (string.Equals(query["step"], "kakeibo", StringComparison.OrdinalIgnoreCase))
        {
            ViewModel.JumpToStep(5);
        }
    }
}
