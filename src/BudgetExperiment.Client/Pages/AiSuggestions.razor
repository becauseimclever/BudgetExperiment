@page "/ai"
@page "/ai/suggestions"
@page "/category-suggestions"
@using BudgetExperiment.Client.Components.AI
@using BudgetExperiment.Client.Components.Common
@using BudgetExperiment.Client.ViewModels
@using BudgetExperiment.Contracts.Dtos
@implements IDisposable
@inject AiSuggestionsViewModel ViewModel

<PageHeader Title="AI Suggestions" Subtitle="Review and manage AI-generated suggestions" />

<div class="suggestions-page">
    <div class="suggestions-toolbar">
        <div class="toolbar-left">
            <Button Variant="ButtonVariant.Primary"
                    IconLeft="sparkles"
                    IsDisabled="@(ViewModel.IsAnalyzing || !ViewModel.IsAiAvailable)"
                    IsLoading="@ViewModel.IsAnalyzing"
                    OnClick="ViewModel.StartAnalysisAsync">
                Run AI Analysis
            </Button>

            <Button Variant="ButtonVariant.Secondary"
                    IconLeft="refresh-cw"
                    IsDisabled="@ViewModel.IsLoading"
                    OnClick="ViewModel.LoadAllSuggestionsAsync">
                Refresh
            </Button>

            @if (ViewModel.TotalSuggestionCount > 0)
            {
                <Button Variant="ButtonVariant.Secondary"
                        Size="ButtonSize.Small"
                        IconLeft="@(ViewModel.IsReviewMode ? "list" : "play")"
                        OnClick="ViewModel.ToggleReviewMode">
                    @(ViewModel.IsReviewMode ? "Exit Review" : "Review Mode")
                </Button>
            }
        </div>

        <div class="toolbar-right">
            <AiStatusBadge />

            @if (ViewModel.TotalSuggestionCount > 1)
            {
                <Button Variant="ButtonVariant.Danger"
                        Size="ButtonSize.Small"
                        IconLeft="x"
                        IsDisabled="@ViewModel.IsProcessing"
                        OnClick="ViewModel.DismissAllAsync">
                    Dismiss All
                </Button>
            }
        </div>
    </div>

    <AnalysisInlineProgress IsAnalyzing="@ViewModel.IsAnalyzing"
                            ElapsedTime="@ViewModel.AnalysisElapsed"
                            ErrorMessage="@ViewModel.AnalysisError"
                            RuleResult="@ViewModel.RuleAnalysisResult"
                            CategoryCount="@ViewModel.CategoryAnalysisCount"
                            OnRetry="ViewModel.StartAnalysisAsync"
                            OnDismiss="ViewModel.DismissAnalysisResult" />

    @if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
    {
        <ErrorAlert Message="@ViewModel.ErrorMessage" TraceId="@ViewModel.ErrorTraceId" OnDismiss="ViewModel.DismissError" />
    }

    @if (!string.IsNullOrEmpty(ViewModel.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @ViewModel.SuccessMessage
            <button type="button" class="btn-close" @onclick="ViewModel.DismissSuccess" aria-label="Close"></button>
        </div>
    }

    @if (ViewModel.Metrics is { } metrics && (metrics.Accepted > 0 || metrics.Dismissed > 0))
    {
        <div class="metrics-summary">
            <span class="metrics-label">Suggestion Performance:</span>
            <span class="metrics-stat">
                <strong>@metrics.Accepted</strong> of <strong>@(metrics.Accepted + metrics.Dismissed)</strong> accepted
                @if (metrics.AcceptanceRate.HasValue)
                {
                    <span class="metrics-rate">(@((metrics.AcceptanceRate.Value * 100).ToString("F0"))%)</span>
                }
            </span>
            @if (metrics.Pending > 0)
            {
                <span class="metrics-stat metrics-pending">@metrics.Pending pending</span>
            }
        </div>
    }

    @if (ViewModel.IsLoading)
    {
        <LoadingSpinner Message="Loading suggestions..." />
    }
    else if (!ViewModel.IsAiAvailable)
    {
        <AiSetupBanner State="AiSetupState.NotConfigured" />
    }
    else if (ViewModel.IsAllCaughtUp && ViewModel.RuleAnalysisResult == null && !ViewModel.CategoryAnalysisCount.HasValue)
    {
        @if (ViewModel.Status != null)
        {
            <AiSetupBanner State="AiSetupState.AllCaughtUp" />
        }
        else
        {
            <AiSetupBanner State="AiSetupState.NoSuggestions" />
        }
    }
    else if (ViewModel.TotalSuggestionCount == 0 && !ViewModel.IsAnalyzing)
    {
        <AiSetupBanner State="AiSetupState.NoSuggestions" />
    }
    else if (ViewModel.IsReviewMode)
    {
        var allItems = GetAllItemsFlat();
        if (ViewModel.ReviewIndex < allItems.Count)
        {
            var currentItem = allItems[ViewModel.ReviewIndex];
            <div class="review-mode-container">
                <div class="review-progress">
                    <span>Suggestion @(ViewModel.ReviewIndex + 1) of @allItems.Count</span>
                    <div class="review-progress-bar">
                        <div class="review-progress-fill" style="width: @(((ViewModel.ReviewIndex + 1) * 100.0 / allItems.Count).ToString("F0"))%"></div>
                    </div>
                </div>

                <UnifiedSuggestionCard Item="@currentItem"
                                       OnAccept="HandleReviewAccept"
                                       OnDismiss="HandleReviewDismiss"
                                       OnFeedback="HandleReviewFeedback" />

                <div class="review-nav">
                    <Button Variant="ButtonVariant.Secondary" IconLeft="skip-forward" OnClick="ViewModel.SkipReviewItem">Skip</Button>
                </div>
            </div>
        }
        else
        {
            <AiSetupBanner State="AiSetupState.AllCaughtUp" />
        }
    }
    else
    {
        @foreach (var group in ViewModel.GroupedSuggestions)
        {
            <SuggestionGroup Group="@group"
                             OnAcceptRule="ViewModel.AcceptRuleSuggestionAsync"
                             OnDismissRule="ViewModel.DismissRuleSuggestionAsync"
                             OnAcceptCategory="HandleAcceptCategory"
                             OnDismissCategory="ViewModel.DismissCategorySuggestionAsync"
                             OnFeedback="HandleFeedback"
                             OnAcceptAllHighConfidence="ViewModel.AcceptAllHighConfidenceAsync"
                             IsProcessing="@ViewModel.IsProcessing" />
        }
    }
</div>

@code {
    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        ViewModel.OnStateChanged = () => InvokeAsync(StateHasChanged);
        await ViewModel.InitializeAsync();
    }

    private async Task HandleAcceptCategory(Guid id)
    {
        await ViewModel.AcceptCategorySuggestionAsync(id);
    }

    private async Task HandleFeedback((Guid Id, bool IsPositive) feedback)
    {
        await ViewModel.ProvideFeedbackAsync(feedback.Id, feedback.IsPositive);
    }

    private async Task HandleReviewAccept(Guid id)
    {
        var item = GetAllItemsFlat().ElementAtOrDefault(ViewModel.ReviewIndex);
        if (item is CategorySuggestionDto)
        {
            await ViewModel.AcceptCategorySuggestionAsync(id);
        }
        else
        {
            await ViewModel.AcceptRuleSuggestionAsync(id);
        }
    }

    private async Task HandleReviewDismiss(Guid id)
    {
        var item = GetAllItemsFlat().ElementAtOrDefault(ViewModel.ReviewIndex);
        if (item is CategorySuggestionDto)
        {
            await ViewModel.DismissCategorySuggestionAsync(id);
        }
        else
        {
            await ViewModel.DismissRuleSuggestionAsync(id);
        }
    }

    private async Task HandleReviewFeedback((Guid Id, bool IsPositive) feedback)
    {
        await ViewModel.ProvideFeedbackAsync(feedback.Id, feedback.IsPositive);
    }

    private List<object> GetAllItemsFlat()
    {
        return ViewModel.GroupedSuggestions.SelectMany(g => g.Items).ToList();
    }

    /// <inheritdoc />
    public void Dispose()
    {
        ViewModel.OnStateChanged = null;
        ViewModel.Dispose();
    }
}
