# Environment variables for BudgetExperiment Docker deployment
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =============================================================================
# Database Connection String
# =============================================================================
# Replace with your actual PostgreSQL connection details.
# Not needed for docker-compose.demo.yml (bundled PostgreSQL).
DB_CONNECTION_STRING=Host=your-db-server-hostname-or-ip;Port=5432;Database=budgetexperiment;Username=your-username;Password=your-password;SSL Mode=Prefer

# Example for local PostgreSQL on same network:
# DB_CONNECTION_STRING=Host=192.168.1.100;Port=5432;Database=budgetexperiment;Username=budgetuser;Password=SecurePassword123!

# Example for PostgreSQL with SSL:
# DB_CONNECTION_STRING=Host=db.example.com;Port=5432;Database=budgetexperiment;Username=budgetuser;Password=SecurePassword123!;SSL Mode=Require

# Optional: Override default port mapping (default is 5099:8080)
# BUDGET_APP_PORT=5099

# =============================================================================
# Authentication Mode
# =============================================================================
# "None" = authentication disabled (demo/family use)
# "OIDC" = authentication enabled via an OIDC provider (default)
#
# For docker-compose.demo.yml this defaults to None.
# For docker-compose.pi.yml set to OIDC and configure a provider below.
# AUTHENTICATION_MODE=OIDC

# =============================================================================
# Provider Selection (when Mode = OIDC)
# =============================================================================
# "Authentik" (default), "Google", "Microsoft", "OIDC" (generic)
# AUTHENTICATION_PROVIDER=Authentik

# =============================================================================
# Authentik Provider
# =============================================================================
# AUTHENTIK_AUTHORITY=https://your-authentik.example.com/application/o/budget-experiment/
# AUTHENTIK_AUDIENCE=your-client-id
# AUTHENTIK_REQUIRE_HTTPS=true

# =============================================================================
# Google OAuth Provider
# =============================================================================
# Create credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=123456789-xyz.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx

# =============================================================================
# Microsoft Entra ID Provider
# =============================================================================
# Register an app at https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# MICROSOFT_CLIENT_ID=00000000-0000-0000-0000-000000000000
# MICROSOFT_TENANT_ID=common
# MICROSOFT_CLIENT_SECRET=xxx  # Optional for public clients

# =============================================================================
# Generic OIDC Provider (Keycloak, Auth0, Okta, etc.)
# =============================================================================
# OIDC_AUTHORITY=https://keycloak.example.com/realms/master
# OIDC_CLIENT_ID=budget-experiment
# OIDC_CLIENT_SECRET=xxx
# OIDC_AUDIENCE=budget-experiment
# OIDC_REQUIRE_HTTPS=true
# For custom scopes, set via Authentication__Oidc__Scopes__0=openid etc.
# For claim mappings, set via Authentication__Oidc__ClaimMappings__name=preferred_username etc.
